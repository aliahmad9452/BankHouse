<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DashboardMetric">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">88dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_metric_card</item>
        <item name="android:elevation">1dp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">10dp</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BankHouseButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/white</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="BankHouseButton.Primary">
        <item name="backgroundTint">@color/income_green</item>
    </style>

    <style name="BankHouseButton.Danger">
        <item name="backgroundTint">@color/expense_red</item>
    </style>

    <style name="BankHouseButton.Tool">
        <item name="backgroundTint">@color/tool_blue</item>
    </style>

    <style name="BankHouseButton.Warm">
        <item name="backgroundTint">@color/tool_amber</item>
    </style>

    <style name="BankHouseButton.Neutral">
        <item name="backgroundTint">@color/primary_green_dark</item>
    </style>
</resources>
